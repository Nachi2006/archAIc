# ── Auth Service ──────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens. Change this in production.
JWT_SECRET=your-secret-key-here

# ── Service URLs (used by product-service) ────────────────────────────────────
# Internal Docker network hostnames. Change to localhost ports for local dev.
AUTH_SERVICE_URL=http://auth-service:8001
DB_SERVICE_URL=http://db-service:8002

# ── Timeouts ──────────────────────────────────────────────────────────────────
# How long (seconds) product-service waits for auth/db responses before timing out
REQUEST_TIMEOUT=8
